# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Federation Configuration
VITE_FEDERATION_ENABLED=true
VITE_INSTANCE_URL=http://localhost:5173
VITE_INSTANCE_NAME=XClone Instance
VITE_INSTANCE_ADMIN_EMAIL=admin@xclone.local
VITE_INSTANCE_DESCRIPTION=A decentralized social platform with Fediverse integration

# RSA Keys (for HTTP signatures)
VITE_FEDERATION_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----
VITE_FEDERATION_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----

# Bluesky Configuration
VITE_BLUESKY_ENABLED=true
VITE_BLUESKY_HANDLE=your-handle.bsky.social
VITE_BLUESKY_PASSWORD=your-app-password
VITE_BLUESKY_API_URL=https://bsky.social/xrpc

# Mastodon Configuration
VITE_MASTODON_ENABLED=true
VITE_MASTODON_INSTANCE=mastodon.social
VITE_MASTODON_ACCESS_TOKEN=your-token

# Lemmy Configuration
VITE_LEMMY_ENABLED=true
VITE_LEMMY_INSTANCE=lemmy.ml
VITE_LEMMY_API_TOKEN=your-token

# Federation Secret Key
VITE_FEDERATION_SECRET=your-secret-key-for-signatures

# Cross-Instance Communication
VITE_TESTAGRAM_GATEWAY_URL=http://localhost:3000
VITE_TESTAGRAM_GATEWAY_SECRET=your-gateway-secret
VITE_XCLONE_API_SECRET=your-xclone-secret
